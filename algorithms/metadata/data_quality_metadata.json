{
  "default_history_size": 5,
  "sensors": {
    "SONBEST_SM9560B": {
      "parameters": {
        "illuminance_lux": {
          "min": 0,
          "max": 65535,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    },
    "Veinasa_THPW_NJ": {
      "parameters": {
        "wind_speed_ms": {
          "min": 0,
          "max": 45,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "wind_direction_deg": {
          "min": 0,
          "max": 359,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "air_temperature_c": {
          "min": -40,
          "max": 80,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "air_humidity_percent": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "air_pressure_hpa": {
          "min": 300,
          "max": 1100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    },
    "XS_TBQ02C": {
      "parameters": {
        "solar_radiation_wm2": {
          "min": 0,
          "max": 2000,
          "rules": [
            {"type": "negative_to_zero"},
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    },
    "SONBEST_XM8504": {
      "parameters": {
        "rain_interval_mm": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "negative_to_zero"},
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    },
    "TR_4H01X": {
      "parameters": {
        "soil_moisture_probe_1_percent": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "soil_moisture_probe_2_percent": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "soil_moisture_probe_3_percent": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "soil_moisture_probe_4_percent": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    },
    "OPTICAL_RAIN_GAUGE": {
      "parameters": {
        "rainfall_total_mm": {
          "min": 0,
          "max": 6553.5,
          "rules": [
            {"type": "negative_to_zero"},
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "rain_interval_mm": {
          "min": 0,
          "max": 100,
          "rules": [
            {"type": "negative_to_zero"},
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "rain_intensity_mm_min": {
          "min": 0,
          "max": 24,
          "rules": [
            {"type": "negative_to_zero"},
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        },
        "illuminance_lux": {
          "min": 0,
          "max": 200000,
          "rules": [
            {"type": "range_check", "replacement": "median_history"},
            {"type": "clamp"}
          ]
        }
      }
    }
  }
}
