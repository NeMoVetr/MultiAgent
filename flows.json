    {
        "id": "bbb3e5cf99599580",
        "type": "function",
        "z": "e367cff56b45ef57",
        "name": "SONBEST SM9560B",
        "func": "let base = flow.get(\"luxBase\") || 28000;\nconst variation = Math.random() * 14000 - 7000;\nlet lux = Math.max(0, Math.min(65535, Math.round(base + variation)));\nflow.set(\"luxBase\", lux);\n\nmsg.topic = \"sensors/8f3e2a1c-9b7d-4e5f-a1b2-c3d4e5f6a7b8\";   // ← твой UUID\n\nmsg.payload = {\n    value: lux,\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
