    {
        "id": "69499409b420aeec",
        "type": "function",
        "z": "e367cff56b45ef57",
        "name": "Veinasa THPW-NJ",
        "func": "let windBase = flow.get(\"windBase\") || 4;\nlet tempBase = flow.get(\"tempBase\") || 19;\n\nconst windSpeed = Math.max(0, Math.round((windBase + Math.random()*5 - 2.5)*10)/10);\nconst windDir   = Math.floor(Math.random()*360);\nconst temp = Math.round((tempBase + Math.random()*8 - 4)*10)/10;\nconst hum  = Math.round(40 + Math.random()*50);\nconst press = Math.round(985 + Math.random()*35);\n\nflow.set(\"windBase\", windSpeed);\nflow.set(\"tempBase\", temp);\n\nmsg.topic = \"sensors/1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d\";   // ← твой UUID\n\nmsg.payload = {\n    wind_speed: windSpeed,\n    wind_direction: windDir,\n    temperature: temp,\n    humidity: hum,\n    pressure: press,\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
