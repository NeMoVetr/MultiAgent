    {
        "id": "aa6f675f355d31d9",
        "type": "function",
        "z": "e367cff56b45ef57",
        "name": "SONBEST SM7005",
        "func": "let intensity = flow.get(\"rainIntensity\") || 0;\nif (Math.random() < 0.08) {\n    intensity = Math.random() < 0.35 ? 0 : Math.random() * 4;\n}\nlet accum = (flow.get(\"rainAccum\") || 0) + (intensity / 12);\n\nflow.set(\"rainIntensity\", intensity);\nflow.set(\"rainAccum\", accum);\n\nmsg.topic = \"sensors/4b5c6d7e-8f9a-0b1c-2d3e-4f5a6b7c8d9e\";   // ← твой UUID\n\nmsg.payload = {\n    rain_intensity: Math.round(intensity*10)/10,\n    rain_accum_today: Math.round(accum*10)/10,\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
